{
  "WanVideoSamplerv2": {
    "required": {
      "model": [
        "WANVIDEOMODEL"
      ],
      "image_embeds": [
        "WANVIDIMAGE_EMBEDS"
      ],
      "cfg": [
        "FLOAT",
        {
          "default": 6.0,
          "min": 0.0,
          "max": 30.0,
          "step": 0.01
        }
      ],
      "seed": [
        "INT",
        {
          "default": 0,
          "min": 0,
          "max": 18446744073709551615
        }
      ],
      "force_offload": [
        "BOOLEAN",
        {
          "default": true,
          "tooltip": "Moves the model to the offload device after sampling"
        }
      ],
      "scheduler": [
        "WANVIDEOSCHEDULER"
      ]
    },
    "optional": {
      "text_embeds": [
        "WANVIDEOTEXTEMBEDS"
      ],
      "samples": [
        "LATENT",
        {
          "tooltip": "init Latents to use for video2video process"
        }
      ],
      "add_noise_to_samples": [
        "BOOLEAN",
        {
          "default": false,
          "tooltip": "Add noise to the samples before sampling, needed for video2video sampling when starting from clean video"
        }
      ],
      "extra_args": [
        "WANVIDSAMPLEREXTRAARGS"
      ]
    }
  },
